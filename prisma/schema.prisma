// Prisma client generator
generator client {
  provider = "prisma-client-js"
}

// SQLite database
datasource db {
  provider = "sqlite"
}

// Each SEO agent run
model Run {
  id        String   @id @default(uuid())
  domain    String
  topic     String
  keywords  String   // JSON/text later
  brief     String   // AI output
  createdAt DateTime @default(now())
}

// Each crawled page
model Page {
  id        String   @id @default(uuid())
  url       String   @unique
  title     String?
  headings  String? // Stored as string
  createdAt DateTime @default(now())
}
